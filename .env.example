# NBA Playoff Terminal - Environment Variables

# The Odds API (free: 500 req/month) - https://the-odds-api.com
ODDS_API_KEY=

# BallDontLie API (free tier) - https://www.balldontlie.io
BDL_API_KEY=

# Upstash Redis (free tier) - https://upstash.com
# Required for Vercel deployment (persistent user/slip data)
# Create a free Redis DB at console.upstash.com, copy REST URL + token
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Server port (default: 3000)
PORT=3000
